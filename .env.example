# ─────────────────────────────────────────────────────────────
# PawsPair — environment template. Copy to .env and fill in.
# ─────────────────────────────────────────────────────────────

# Database
# Local dev (SQLite, default):
DATABASE_URL="file:./dev.db"
# Production (PlanetScale / MySQL) — use prisma/schema.mysql.prisma:
# DATABASE_URL="mysql://USER:PASSWORD@HOST/pawspair?sslaccept=strict"

# Auth — REQUIRED in production (the app refuses to run without a 32+ char value).
# Generate one with:  openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-secret-min-32-chars"

# ── Razorpay (optional). Leave blank to keep payments SIMULATED. ──
# When all of KEY_ID/KEY_SECRET are set, live checkout activates.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
# Plan IDs created in the Razorpay dashboard (Subscriptions → Plans):
RAZORPAY_PLAN_FETCH=""
RAZORPAY_PLAN_PEDIGREE=""

# Web Push (VAPID) — generate with:  npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:hello@yourdomain"

# Email (optional) — welcome emails to subscribers. Leave blank to skip sending.
RESEND_API_KEY=""
EMAIL_FROM="PawsPair <hello@yourdomain>"

# Cron secret — REQUIRED to enable /api/cron/daily-thought. When blank the endpoint
# is disabled (returns 503) so it can't be triggered publicly. Set it, then call daily
# from Vercel Cron / GitHub Actions with header: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

# Gmail SMTP (official sender) — generate an App Password at myaccount.google.com/apppasswords
GMAIL_USER="pawspair@gmail.com"
GMAIL_APP_PASSWORD=""
EMAIL_FROM="PawsPair <pawspair@gmail.com>"
