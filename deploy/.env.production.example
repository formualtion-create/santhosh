# ─────────────────────────────────────────────────────────────────────────
# PawsPair — PRODUCTION environment template
# Copy this to the project root as `.env` and fill in. Never commit the real .env.
# Every block is independent: leave a feature's vars blank to keep it simulated/off.
# ─────────────────────────────────────────────────────────────────────────

# ── REQUIRED ───────────────────────────────────────────────────────────────
# Session secret — the app refuses to boot in production without ≥32 chars.
# Generate:  openssl rand -base64 32
AUTH_SECRET=""

# Database. Local dev default is SQLite; production = PlanetScale/MySQL
# (first run: cp prisma/schema.mysql.prisma prisma/schema.prisma)
DATABASE_URL="mysql://USER:PASSWORD@HOST/pawspair?sslaccept=strict"

# Your public site URL — used for canonical tags, sitemap, OG images, email links.
NEXT_PUBLIC_SITE_URL="https://pawspair.in"

# ── Payments: Razorpay (blank = simulated checkout) ─────────────────────────
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
RAZORPAY_PLAN_FETCH=""        # plan_xxx
RAZORPAY_PLAN_PEDIGREE=""     # plan_yyy

# ── Email: choose ONE provider (blank = OTP/codes shown on-screen, demo mode) ─
# Option A — Gmail SMTP (App Password from myaccount.google.com/apppasswords, 2FA on)
GMAIL_USER="pawspair@gmail.com"
GMAIL_APP_PASSWORD=""
# Option B — Resend (uncomment to use instead of Gmail)
# RESEND_API_KEY=""
# The visible sender (set to a verified address for your chosen provider)
EMAIL_FROM="PawsPair <pawspair@gmail.com>"

# ── Web Push (generate: npx web-push generate-vapid-keys) ────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:hello@yourdomain.com"

# ── Daily-thought cron (blank = endpoint disabled / returns 503) ─────────────
CRON_SECRET=""

# ── Beta phase ──────────────────────────────────────────────────────────────
# Set NEXT_PUBLIC_BETA="0" to leave beta (hides badge/banner/notices).
# Set BETA_INVITE_CODE to a shared code = invite-only signup; blank = open.
NEXT_PUBLIC_BETA="1"
BETA_INVITE_CODE="choose-a-code"
